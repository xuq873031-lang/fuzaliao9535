APP_ENV=development
APP_NAME=chat-backend
SECRET_KEY=replace-this-with-a-long-random-secret
# 本地开发可用 SQLite；production 请使用 PostgreSQL
DATABASE_URL=sqlite:///./chat_app.db
FRONTEND_ORIGINS=https://<your-github-pages-domain>,http://localhost:5500,http://127.0.0.1:5500
ACCESS_TOKEN_EXPIRE_HOURS=72

# 生产护栏：production 默认不允许 SQLite
ENFORCE_NON_SQLITE_IN_PRODUCTION=true

# 生产护栏：production 默认不允许本地 uploads
# 若短期无法接对象存储，请显式设为 true（并知晓数据丢失风险）
ALLOW_LOCAL_UPLOADS_IN_PRODUCTION=false

# 可发起加好友/好友申请的角色与账号（后端强校验）
FRIEND_REQUEST_ALLOWED_ROLES=admin,mentor
FRIEND_REQUEST_ALLOWED_USERNAMES=

# 上传目录（相对 backend 目录）
UPLOAD_DIR=uploads
