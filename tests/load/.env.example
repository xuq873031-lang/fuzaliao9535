# HTTP API base（不要用线上正式环境做高并发）
LOAD_BASE_URL=https://web-production-be9f.up.railway.app

# WebSocket base（可留空，脚本会由 LOAD_BASE_URL 推导）
# 例如：wss://web-production-be9f.up.railway.app
LOAD_WS_BASE=

# 测试账号前缀，脚本会生成 <prefix>_0001 ...
LOAD_USER_PREFIX=loaduser
LOAD_PASSWORD=loadpass123

# 可选：预置房间 ID（如果不填，脚本会自动创建一个共享房间）
LOAD_ROOM_ID=

# 默认并发用户
LOAD_USERS=10

# 每个场景持续秒数（ws/chat）
LOAD_DURATION_SEC=60

# chat 场景每个用户发送间隔（秒）
LOAD_SEND_INTERVAL_SEC=2.0
